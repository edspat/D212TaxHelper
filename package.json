{
  "name": "d212-tax-helper",
  "version": "2.1.0",
  "description": "D212 Tax Helper - Investment tax calculator for Romanian tax declarations",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "watch": "node -e \"const{execSync}=require('child_process');while(true){try{execSync('node server.js',{stdio:'inherit'})}catch(e){console.log('Server stopped. Restarting...')}}\"\n",
    "extract": "node scripts/extract-pdfs.js",
    "dev": "node server.js"
  },
  "dependencies": {
    "express": "^4.21.0",
    "multer": "^1.4.5-lts.1",
    "pdf-parse-new": "^2.0.0",
    "tesseract.js": "^5.1.1",
    "xlsx": "^0.18.5"
  }
}
